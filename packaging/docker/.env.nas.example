# =============================================================================
# TorZlink NAS (.env) — copy to your deploy dir as `.env` (chmod 600)
# Do not commit real secrets. Reuse names from your homelab stack where possible.
# =============================================================================

# direct = Traefik proxy_net (NAS public IP on swarm)
# vpn    = share Gluetun netns (Mullvad); add labels from traefik-gluetun-torzlink.labels.md
TORZLINK_NETWORK_MODE=direct

# Required when TORZLINK_NETWORK_MODE=direct (docker network ls)
PROXY_NET_NAME=

# Used when TORZLINK_NETWORK_MODE=vpn
GLUETUN_CONTAINER_NAME=gluetun

DOCKER_CONFIG_ROOT=/volume2/Docker_Configs
MEDIA_ROOT=/volume1/data
TZ=Europe/Madrid
PUID=1000
PGID=10

TORZLINK_IMAGE_TAG=latest

# Optional: require Bearer token on /api/* (recommended on shared Docker networks)
# TORZLINK_SERVE_TOKEN=change-me-long-random

# Optional Telegram (same vars as desktop TorZlink)
# TELEGRAM_ENABLED=1
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
