# =============================================================================
# TorZlink NAS (.env) — copy to your deploy dir as `.env` (chmod 600)
# Do not commit real secrets. Reuse names from your homelab stack where possible.
#
# Ugreen layout (this fork's convention):
#   /volume1  → datos (media / descargas)
#   /volume2  → aplicaciones, configs Docker, compose de despliegue
# =============================================================================

# direct = Traefik proxy_net (NAS public IP on swarm)
# vpn    = share Gluetun netns (Mullvad); add labels from traefik-gluetun-torzlink.labels.md
TORZLINK_NETWORK_MODE=direct

# Required when TORZLINK_NETWORK_MODE=direct (docker network ls)
PROXY_NET_NAME=0-nas_proxy_net

# Used when TORZLINK_NETWORK_MODE=vpn
GLUETUN_CONTAINER_NAME=gluetun

# Full image reference (preferred)
# From PC (deploy-from-dev):  torzlink:v1.7.1
# From GHCR:                  ghcr.io/tiizss/torzlink:v1.7.1
TORZLINK_IMAGE=torzlink:v1.7.1

# Deploy working dir on NAS (must be writable by SSH user)
# /volume2/docker is often root-only; use Docker_Configs instead:
# TORZLINK_DEPLOY_DIR is set by deploy-from-dev; compose lives there.

# Apps / container config (SSD / volume2)
DOCKER_CONFIG_ROOT=/volume2/Docker_Configs
# Media root (HDD / volume1) — used by docs / helpers
MEDIA_ROOT=/volume1/data
# Downloads bind-mount on the NAS (container path remains /downloads)
TORZLINK_DOWNLOADS_HOST=/volume1/data/media/descargas/torrents

TZ=Europe/Madrid
# Must be able to write TORZLINK_DOWNLOADS_HOST (typically 1000:1000 on Ugreen)
PUID=1000
PGID=1000

# Recommended on shared Docker networks (proxy_net): Bearer required on /api/*
# Deploy scripts generate one if missing.
# TORZLINK_SERVE_TOKEN=change-me-long-random

# Optional Telegram (same vars as desktop TorZlink)
# TELEGRAM_ENABLED=1
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=
